<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.scene.control.Button?>
<?import javafx.scene.control.ComboBox?>
<?import javafx.scene.control.Label?>
<?import javafx.scene.control.TableColumn?>
<?import javafx.scene.control.TableView?>
<?import javafx.scene.control.TextField?>
<?import javafx.scene.image.Image?>
<?import javafx.scene.image.ImageView?>
<?import javafx.scene.layout.AnchorPane?>
<?import javafx.scene.layout.HBox?>
<?import javafx.scene.layout.Region?>
<?import javafx.scene.layout.VBox?>
<?import javafx.scene.text.Font?>

<AnchorPane prefHeight="800.0" prefWidth="1000.0" style="-fx-background-color: #e1ede7;" xmlns="http://javafx.com/javafx/21" xmlns:fx="http://javafx.com/fxml/1" fx:controller="org.example.serenitytherapycenterorm.controller.PatientController">
    <children>
        <VBox spacing="25.0" AnchorPane.bottomAnchor="20.0" AnchorPane.leftAnchor="25.0" AnchorPane.rightAnchor="25.0" AnchorPane.topAnchor="20.0">
            <children>
                <HBox alignment="CENTER_LEFT">
                    <children>
                        <Label text="Manage Patients" textFill="#2D5F4E">
                            <font>
                                <Font name="System Bold" size="28.0" />
                            </font>
                            <graphic>
                                <ImageView fitHeight="36.0" fitWidth="36.0" pickOnBounds="true" preserveRatio="true">
                                    <image>
                                        <Image url="@../icon/patienticon.png" />
                                    </image>
                                </ImageView>
                            </graphic>
                        </Label>
                    </children>
                </HBox>

                <HBox spacing="50.0" VBox.vgrow="NEVER">
                    <children>
                        <VBox prefHeight="95.0" style="-fx-background-color: white; -fx-background-radius: 15; -fx-padding: 15; -fx-effect: dropshadow(three-pass-box, rgba(0,0,0,0.04), 10, 0, 0, 4);" HBox.hgrow="ALWAYS">
                            <children>
                                <Label text="Total Patients" textFill="#757575">
                                    <font>
                                        <Font size="13.0" />
                                    </font></Label>
                                <Label fx:id="lblTotalPatients" text="1,248" textFill="#2D5F4E">
                                    <font>
                                        <Font name="System Bold" size="24.0" />
                                    </font>
                                </Label>
                                <Region VBox.vgrow="ALWAYS" />
                                <Label text="● Active patients" textFill="#4CAF50">
                                    <font>
                                        <Font name="System Bold" size="11.0" />
                                    </font></Label>
                            </children>
                        </VBox>
                        <VBox prefHeight="95.0" style="-fx-background-color: white; -fx-background-radius: 15; -fx-padding: 15; -fx-effect: dropshadow(three-pass-box, rgba(0,0,0,0.04), 10, 0, 0, 4);" HBox.hgrow="ALWAYS">
                            <children>
                                <Label text="Inactive Patients" textFill="#757575">
                                    <font>
                                        <Font size="13.0" />
                                    </font></Label>
                                <Label fx:id="lblInactivePatients" text="56" textFill="#2D5F4E">
                                    <font>
                                        <Font name="System Bold" size="24.0" />
                                    </font>
                                </Label>
                                <Region VBox.vgrow="ALWAYS" />
                                <Label text="● Inactive Patients" textFill="#d45b55">
                                    <font>
                                        <Font name="System Bold" size="11.0" />
                                    </font></Label>
                            </children>
                        </VBox>
                        <VBox prefHeight="95.0" style="-fx-background-color: white; -fx-background-radius: 15; -fx-padding: 15; -fx-effect: dropshadow(three-pass-box, rgba(0,0,0,0.04), 10, 0, 0, 4);" HBox.hgrow="ALWAYS">
                            <children>
                                <Label text="Completed Treatments" textFill="#757575">
                                    <font>
                                        <Font size="13.0" />
                                    </font></Label>
                                <Label fx:id="lblCompletedTreatments" text="356" textFill="#2D5F4E">
                                    <font>
                                        <Font name="System Bold" size="24.0" />
                                    </font>
                                </Label>
                                <Region VBox.vgrow="ALWAYS" />
                                <Label text="● Successfully completed" textFill="#4CAF50">
                                    <font>
                                        <Font name="System Bold" size="11.0" />
                                    </font></Label>
                            </children>
                        </VBox>
                    </children>
                </HBox>

                <VBox spacing="15.0" style="-fx-background-color: white; -fx-background-radius: 20; -fx-padding: 20; -fx-effect: dropshadow(three-pass-box, rgba(0,0,0,0.04), 15, 0, 0, 5);" VBox.vgrow="ALWAYS">
                    <children>
                        <HBox alignment="CENTER_LEFT" spacing="12.0" VBox.vgrow="NEVER">
                            <children>
                                <HBox alignment="CENTER_LEFT" prefHeight="36.0" prefWidth="280.0" style="-fx-background-color: #F5F5F5; -fx-background-radius: 8; -fx-border-color: #E0E0E0; -fx-border-radius: 8; -fx-padding: 0 8 0 8;">
                                    <children>
                                        <ImageView fitHeight="20.0" fitWidth="20.0" pickOnBounds="true" preserveRatio="true" style="-fx-opacity: 0.5;">
                                            <image>
                                                <Image url="@../icon/searchicon.png" />
                                            </image>
                                        </ImageView>
                                        <TextField fx:id="txtSearch" onAction="#handleSearchEnter" prefHeight="32.0" promptText="Search by name or ID" style="-fx-background-color: transparent; -fx-prompt-text-fill: #9E9E9E;" HBox.hgrow="ALWAYS">
                                            <font>
                                                <Font size="13.0" />
                                            </font></TextField>
                                    </children>
                                </HBox>
                                <ComboBox fx:id="cmbFilterStatus" prefHeight="36.0" prefWidth="150.0" promptText="All Status" style="-fx-background-color: white; -fx-border-color: #E0E0E0; -fx-border-radius: 8;" />
                                <ComboBox fx:id="cmbFilterPrograms" prefHeight="36.0" prefWidth="160.0" promptText="All Programs" style="-fx-background-color: white; -fx-border-color: #E0E0E0; -fx-border-radius: 8;" />
                                <Region HBox.hgrow="ALWAYS" />
                        <Button mnemonicParsing="false" onAction="#handleDeletePatientClick" prefHeight="35.0" prefWidth="105.0" style="-fx-background-color: #d45b55; -fx-background-radius: 10;" text="Delete" textFill="#ffffffc6">
                           <font>
                              <Font name="System Bold" size="14.0" />
                           </font>
                        </Button>
                                <Button fx:id="btnAddNewPatient" onAction="#handleAddNewPatientClick" prefHeight="38.0" prefWidth="160.0" style="-fx-background-color: #2D5F4E; -fx-text-fill: white; -fx-background-radius: 8; -fx-font-weight: bold; -fx-cursor: hand;" text="+ Add New Patient">
                                    <font>
                                        <Font size="13.0" />
                                    </font>
                                </Button>
                            </children>
                        </HBox>

                        <TableView fx:id="tblPatient" style="-fx-background-radius: 10; -fx-border-radius: 10; -fx-background-color: transparent;" VBox.vgrow="ALWAYS">
                            <columns>
                                <TableColumn fx:id="colId" minWidth="60.0" prefWidth="70.0" text="ID" />
                                <TableColumn fx:id="colName" minWidth="120.0" prefWidth="150.0" text="Patient Name" />
                                <TableColumn fx:id="colContact" minWidth="102.40003967285156" prefWidth="102.40003967285156" text="Contact" />
                                <TableColumn fx:id="colDOB" minWidth="97.60003662109375" prefWidth="120.0" text="Date of Birth" />
                                <TableColumn fx:id="colAddress" minWidth="93.60000610351562" prefWidth="113.60000610351562" text="Address" />
                                <TableColumn fx:id="colPrograms" minWidth="139.20001220703125" prefWidth="146.39996337890625" text="Programs" />
                                <TableColumn fx:id="colNote" minWidth="90.0" prefWidth="131.20001220703125" text="Note" />
                                <TableColumn fx:id="colStatus" minWidth="93.599853515625" prefWidth="93.599853515625" text="Status" />
                            </columns>
                            <columnResizePolicy>
                                <TableView fx:constant="CONSTRAINED_RESIZE_POLICY" />
                            </columnResizePolicy>
                        </TableView>
                    </children>
                </VBox>
            </children>
        </VBox>
    </children>
</AnchorPane>
