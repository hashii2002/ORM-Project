<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.geometry.Insets?>
<?import javafx.scene.control.Button?>
<?import javafx.scene.control.ComboBox?>
<?import javafx.scene.control.Label?>
<?import javafx.scene.control.TableColumn?>
<?import javafx.scene.control.TableView?>
<?import javafx.scene.control.TextField?>
<?import javafx.scene.image.Image?>
<?import javafx.scene.image.ImageView?>
<?import javafx.scene.layout.AnchorPane?>
<?import javafx.scene.layout.HBox?>
<?import javafx.scene.layout.Region?>
<?import javafx.scene.layout.VBox?>
<?import javafx.scene.text.Font?>

<AnchorPane prefHeight="800.0" prefWidth="1020.0" style="-fx-background-color: #e1ede7;" xmlns="http://javafx.com/javafx/21" xmlns:fx="http://javafx.com/fxml/1" fx:controller="org.example.serenitytherapycenterorm.controller.PatientController">
    <children>
        <VBox layoutX="30.0" layoutY="20.0" prefWidth="1040.0" spacing="25.0">
            <children>
                <HBox alignment="CENTER_LEFT" spacing="20.0">
                    <children>
                        <VBox>
                            <children>
                                <Label text="Manage Patients" textFill="#2D5F4E">
                                    <font>
                                        <Font name="System Bold" size="28.0" />
                                    </font>
                                    <graphic>
                                        <ImageView fitHeight="44.0" fitWidth="51.0" pickOnBounds="true" smooth="false">
                                            <image>
                                                <Image url="@../icon/patienticon.png" />
                                            </image>
                                        </ImageView>
                                    </graphic>
                                    <padding>
                                        <Insets left="5.0" />
                                    </padding>
                                </Label>
                            </children>
                        </VBox>
                        <Region HBox.hgrow="ALWAYS" />
                    </children>
                </HBox>

                <HBox prefHeight="110.0" prefWidth="1008.0" spacing="15.0">
                    <children>
                        <VBox prefHeight="100.0" prefWidth="245.0" style="-fx-background-color: white; -fx-background-radius: 15; -fx-padding: 20; -fx-effect: dropshadow(three-pass-box, rgba(0,0,0,0.05), 10, 0, 0, 5);">
                            <children>
                                <Label text="Total Patients" textFill="#757575" />
                                <Label text="1,248" textFill="#2D5F4E">
                                    <font>
                                        <Font name="System Bold" size="24.0" />
                                    </font>
                                </Label>
                                <Label text="● Active patients" textFill="#4CAF50" />
                            </children>
                        </VBox>
                        <VBox prefHeight="100.0" prefWidth="245.0" style="-fx-background-color: white; -fx-background-radius: 15; -fx-padding: 20; -fx-effect: dropshadow(three-pass-box, rgba(0,0,0,0.05), 10, 0, 0, 5);">
                            <children>
                                <Label text="Inactive Patients" textFill="#757575" />
                                <Label text="56" textFill="#2D5F4E">
                                    <font>
                                        <Font name="System Bold" size="24.0" />
                                    </font>
                                </Label>
                                <Label text="● Inactive Patients" textFill="#d45b55" />
                            </children>
                        </VBox>
                        <VBox prefHeight="100.0" prefWidth="245.0" style="-fx-background-color: white; -fx-background-radius: 15; -fx-padding: 20; -fx-effect: dropshadow(three-pass-box, rgba(0,0,0,0.05), 10, 0, 0, 5);">
                            <children>
                                <Label text="Ongoing Treatments" textFill="#757575" />
                                <Label text="892" textFill="#2D5F4E">
                                    <font>
                                        <Font name="System Bold" size="24.0" />
                                    </font>
                                </Label>
                                <Label text="● Currently in treatment" textFill="#FFC107" />
                            </children>
                        </VBox>
                        <VBox prefHeight="100.0" prefWidth="245.0" style="-fx-background-color: white; -fx-background-radius: 15; -fx-padding: 20; -fx-effect: dropshadow(three-pass-box, rgba(0,0,0,0.05), 10, 0, 0, 5);">
                            <children>
                                <Label text="Completed Treatments" textFill="#757575" />
                                <Label text="356" textFill="#2D5F4E">
                                    <font>
                                        <Font name="System Bold" size="24.0" />
                                    </font>
                                </Label>
                                <Label text="● Successfully completed" textFill="#4CAF50" />
                            </children>
                        </VBox>
                    </children>
                </HBox>

                <VBox prefHeight="506.0" prefWidth="1006.0" spacing="15.0" style="-fx-background-color: white; -fx-background-radius: 20; -fx-padding: 25; -fx-effect: dropshadow(three-pass-box, rgba(0,0,0,0.05), 15, 0, 0, 5);">
                    <children>
                        <HBox alignment="CENTER_LEFT" spacing="15.0">
                            <children>
                        <HBox prefHeight="40.0" prefWidth="355.0">
                           <children>
                              <ImageView fitHeight="35.0" fitWidth="35.0" pickOnBounds="true" smooth="false">
                                 <image>
                                    <Image url="@../icon/searchicon.png" />
                                 </image>
                              </ImageView>
                                      <TextField prefHeight="35.0" prefWidth="250.0" promptText="Search by name or ID" style="-fx-background-radius: 8;" />
                           </children>
                        </HBox>
                                <ComboBox prefHeight="35.0" prefWidth="187.0" promptText="All Status" style="-fx-background-color: white; -fx-border-color: #E0E0E0; -fx-border-radius: 8;" />
                                <ComboBox prefHeight="35.0" prefWidth="177.0" promptText="All Programs" style="-fx-background-color: white; -fx-border-color: #E0E0E0; -fx-border-radius: 8;" />
                                <Region HBox.hgrow="ALWAYS" />
                                <Button prefHeight="40.0" prefWidth="160.0" style="-fx-background-color: #2D5F4E; -fx-text-fill: white; -fx-background-radius: 12; -fx-font-weight: bold; -fx-cursor: hand;" text="+ Add New Patient">
                           <font>
                              <Font size="13.0" />
                           </font></Button>
                            </children>
                        </HBox>

                        <TableView fx:id="tblPatient" prefHeight="400.0" prefWidth="931.0" style="-fx-background-radius: 10; -fx-border-radius: 10;">
                            <columns>
                                <TableColumn fx:id="colId" prefWidth="71.20001298189163" text="ID" />
                                <TableColumn fx:id="colName" prefWidth="139.2000274658203" text="Patient Name" />
                                <TableColumn fx:id="colContact" prefWidth="119.19996643066406" text="Contact" />
                                <TableColumn fx:id="colDOB" prefWidth="117.60003662109375" text="Date of Birth" />
                                <TableColumn fx:id="colRegDate" prefWidth="121.5999755859375" text="Registered Date" />
                                <TableColumn fx:id="colPrograms" prefWidth="167.20001220703125" text="Programs" />
                                <TableColumn fx:id="colStatus" prefWidth="111.99993896484375" text="Status" />
                                <TableColumn fx:id="colActions" prefWidth="136.800048828125" text="Actions" />
                            </columns>
                        </TableView>
                    </children>
               <opaqueInsets>
                  <Insets />
               </opaqueInsets>
               <VBox.margin>
                  <Insets right="15.0" />
               </VBox.margin>
                </VBox>
            </children>
        </VBox>
    </children>
</AnchorPane>
