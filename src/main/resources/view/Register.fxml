<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.geometry.Insets?>
<?import javafx.scene.control.Button?>
<?import javafx.scene.control.ChoiceBox?>
<?import javafx.scene.control.Hyperlink?>
<?import javafx.scene.control.Label?>
<?import javafx.scene.control.PasswordField?>
<?import javafx.scene.control.TextField?>
<?import javafx.scene.layout.AnchorPane?>
<?import javafx.scene.layout.HBox?>
<?import javafx.scene.layout.Pane?>
<?import javafx.scene.layout.VBox?>
<?import javafx.scene.text.Font?>

<AnchorPane prefHeight="800.0" prefWidth="642.0" xmlns="http://javafx.com/javafx/21" xmlns:fx="http://javafx.com/fxml/1" fx:controller="org.example.serenitytherapycenterorm.controller.RegisterController">
    <children>
        <Pane prefHeight="800.0" prefWidth="642.0">
            <children>
                <VBox alignment="TOP_CENTER" layoutX="47.0" layoutY="60.0" prefHeight="679.0" prefWidth="544.0" style="-fx-effect: dropshadow(three-pass-box, rgba(0,0,0,0.1), 10, 0, 0, 0); -fx-background-color: white; -fx-background-radius: 20; -fx-padding: 40;">
                    <children>
                        <Label alignment="CENTER" prefHeight="30.0" prefWidth="363.0" text="Create New Account" textAlignment="CENTER" textFill="#305e4e">
                            <font>
                                <Font name="Times New Roman Bold" size="28.0" />
                            </font>
                        </Label>
                        <Label alignment="CENTER" prefHeight="22.0" prefWidth="354.0" text="Fill in your details to register" textFill="#2e6952c8">
                            <font>
                                <Font size="15.0" />
                            </font>
                        </Label>
                        <VBox prefHeight="63.0" prefWidth="338.0">
                            <opaqueInsets>
                                <Insets top="10.0" />
                            </opaqueInsets>
                            <VBox.margin>
                                <Insets top="15.0" />
                            </VBox.margin>
                            <children>
                                <Label text="USERNAME" textFill="#356951ba">
                                    <font>
                                        <Font name="System Bold" size="14.0" />
                                    </font>
                                </Label>
                                <TextField fx:id="txtUsername" prefHeight="32.0" prefWidth="338.0" promptText="Enter your UserName" style="-fx-background-radius: 7;">
                                    <font>
                                        <Font size="13.0" />
                                    </font></TextField>
                            </children>
                        </VBox>
                        <VBox prefHeight="66.0" prefWidth="338.0">
                            <opaqueInsets>
                                <Insets top="10.0" />
                            </opaqueInsets>
                            <children>
                                <Label text="FULL NAME" textFill="#356951ba">
                                    <font>
                                        <Font name="System Bold" size="14.0" />
                                    </font>
                                </Label>
                                <TextField fx:id="txtFullName" prefHeight="32.0" prefWidth="338.0" promptText="Enter your Full Name" style="-fx-background-radius: 7;">
                                    <font>
                                        <Font size="13.0" />
                                    </font></TextField>
                            </children>
                        </VBox>
                        <VBox prefHeight="65.0" prefWidth="338.0">
                            <opaqueInsets>
                                <Insets top="10.0" />
                            </opaqueInsets>
                            <children>
                                <Label text="EMAIL" textFill="#356951ba">
                                    <font>
                                        <Font name="System Bold" size="14.0" />
                                    </font>
                                </Label>
                                <TextField fx:id="txtEmail" prefHeight="32.0" prefWidth="338.0" promptText="Enter your Email" style="-fx-background-radius: 7;">
                                    <font>
                                        <Font size="13.0" />
                                    </font></TextField>
                            </children>
                        </VBox>
                        <VBox prefHeight="65.0" prefWidth="338.0">
                            <opaqueInsets>
                                <Insets top="10.0" />
                            </opaqueInsets>
                            <children>
                                <Label text="ADDRESS" textFill="#356951ba">
                                    <font>
                                        <Font name="System Bold" size="14.0" />
                                    </font>
                                </Label>
                                <TextField fx:id="txtAddress" prefHeight="32.0" prefWidth="338.0" promptText="Enter your Address" style="-fx-background-radius: 7;">
                                    <font>
                                        <Font size="13.0" />
                                    </font></TextField>
                            </children>
                        </VBox>
                        <VBox prefHeight="65.0" prefWidth="338.0">
                            <opaqueInsets>
                                <Insets top="10.0" />
                            </opaqueInsets>
                            <children>
                                <Label text="JOB ROLE" textFill="#356951ba">
                                    <font>
                                        <Font name="System Bold" size="14.0" />
                                    </font>
                                </Label>
                                <ChoiceBox fx:id="cmbRole" prefHeight="32.0" prefWidth="338.0" style="-fx-background-radius: 7;" />
                            </children>
                        </VBox>
                        <HBox prefHeight="63.0" prefWidth="338.0">
                            <children>
                                <VBox prefHeight="87.0" prefWidth="238.0">
                                    <children>
                                        <HBox prefHeight="22.0" prefWidth="170.0">
                                            <children>
                                                <Label text="PASSWORD" textFill="#356951ba">
                                                    <font>
                                                        <Font name="System Bold" size="14.0" />
                                                    </font>
                                                </Label>
                                                <Label text="(Min 6 chars)" textFill="#3569519a">
                                                    <font>
                                                        <Font name="System Bold" size="12.0" />
                                                    </font>
                                                    <HBox.margin>
                                                        <Insets left="3.0" />
                                                    </HBox.margin>
                                                </Label>
                                            </children>
                                        </HBox>
                                        <PasswordField fx:id="txtPassword" prefHeight="32.0" prefWidth="238.0" promptText="* * * * * * * * * *" style="-fx-background-radius: 7;">
                                            <font>
                                                <Font size="14.0" />
                                            </font></PasswordField>
                                    </children>
                                </VBox>
                                <VBox prefHeight="50.0" prefWidth="227.0">
                                    <children>
                                        <HBox prefHeight="22.0" prefWidth="227.0">
                                            <children>
                                                <Label text="CONFIRM PASSWORD" textFill="#356951ba">
                                                    <font>
                                                        <Font name="System Bold" size="14.0" />
                                                    </font>
                                                    <HBox.margin>
                                                        <Insets left="10.0" />
                                                    </HBox.margin>
                                                </Label>
                                            </children>
                                        </HBox>
                                        <PasswordField fx:id="txtConfirmPassword" prefHeight="32.0" prefWidth="216.0" promptText="* * * * * * * * * *" style="-fx-background-radius: 7;">
                                            <VBox.margin>
                                                <Insets left="10.0" />
                                            </VBox.margin>
                                            <font>
                                                <Font size="14.0" />
                                            </font>
                                        </PasswordField>
                                    </children>
                                </VBox>
                            </children>
                        </HBox>
                        <VBox alignment="CENTER" prefHeight="115.0" prefWidth="464.0">
                            <children>
                                <Button alignment="CENTER" contentDisplay="CENTER" mnemonicParsing="false" nodeOrientation="LEFT_TO_RIGHT" onAction="#btnCreateAccount" prefHeight="40.0" prefWidth="167.0" style="-fx-background-radius: 12; -fx-background-color: #2D5F4E; -fx-cursor: hand;" text="Create Account" textAlignment="CENTER" textFill="white">
                                    <VBox.margin>
                                        <Insets top="20.0" />
                                    </VBox.margin>
                                    <font>
                                        <Font name="System Bold" size="16.0" />
                                    </font>
                                </Button>
                                <HBox alignment="CENTER" prefHeight="45.0" prefWidth="464.0" spacing="4">
                                    <children>
                                        <Label text="Already have an account?">
                                            <font>
                                                <Font size="13.0" />
                                            </font>
                                        </Label>
                                        <Hyperlink onAction="#linkLoginOnAction" prefHeight="24.0" text="Login" textFill="#221476">
                                            <font>
                                                <Font name="System Bold" size="13.0" />
                                            </font>
                                        </Hyperlink>
                                    </children>
                                </HBox>
                            </children>
                        </VBox>
                    </children>
                </VBox>
            </children>
        </Pane>
    </children>
</AnchorPane>
