<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.geometry.Insets?>
<?import javafx.scene.control.Button?>
<?import javafx.scene.control.ComboBox?>
<?import javafx.scene.control.Label?>
<?import javafx.scene.control.TableColumn?>
<?import javafx.scene.control.TableView?>
<?import javafx.scene.control.TextField?>
<?import javafx.scene.image.Image?>
<?import javafx.scene.image.ImageView?>
<?import javafx.scene.layout.AnchorPane?>
<?import javafx.scene.layout.HBox?>
<?import javafx.scene.layout.Region?>
<?import javafx.scene.layout.VBox?>
<?import javafx.scene.text.Font?>

<AnchorPane prefHeight="800.0" prefWidth="1020.0" style="-fx-background-color: #e1ede7;" xmlns="http://javafx.com/javafx/25" xmlns:fx="http://javafx.com/fxml/1" fx:controller="org.example.serenitytherapycenterorm.controller.UserController">
    <children>
        <VBox layoutX="20.0" layoutY="25.0" spacing="25.0" AnchorPane.bottomAnchor="20.0" AnchorPane.leftAnchor="20.0" AnchorPane.rightAnchor="20.0" AnchorPane.topAnchor="25.0">
            <children>

                <HBox alignment="CENTER_LEFT" spacing="20.0">
                    <children>
                        <VBox>
                            <children>
                                <Label text="Manage Users" textFill="#2D5F4E">
                                    <font>
                                        <Font name="System Bold" size="28.0" />
                                    </font>
                                    <graphic>
                                        <ImageView fitHeight="50.0" fitWidth="53.0" pickOnBounds="true" smooth="false">
                                            <image>
                                                <Image url="@../icon/usericon.png" />
                                            </image>
                                        </ImageView>
                                    </graphic>
                                </Label>
                                <Label text="Dashboard &gt;  Manage Users" textFill="#757575">
                                    <font>
                                        <Font size="13.0" />
                                    </font>
                                    <padding>
                                        <Insets left="60.0" />
                                    </padding>
                                </Label>
                            </children>
                        </VBox>
                        <Region HBox.hgrow="ALWAYS" />
                    </children>
                </HBox>

                <HBox spacing="15.0">
                    <children>
                        <VBox prefHeight="110.0" style="-fx-background-color: white; -fx-background-radius: 15; -fx-padding: 20; -fx-effect: dropshadow(three-pass-box, rgba(0,0,0,0.05), 10, 0, 0, 5);" HBox.hgrow="ALWAYS">
                            <children>
                                <Label text="Total Users" textFill="#757575" />
                                <Label text="24" textFill="#2D5F4E">
                                    <font>
                                        <Font name="System Bold" size="26.0" />
                                    </font>
                                </Label>
                                <Label text="● All system users" textFill="#4CAF50" />
                            </children>
                        </VBox>
                        <VBox prefHeight="110.0" style="-fx-background-color: white; -fx-background-radius: 15; -fx-padding: 20; -fx-effect: dropshadow(three-pass-box, rgba(0,0,0,0.05), 10, 0, 0, 5);" HBox.hgrow="ALWAYS">
                            <children>
                                <Label text="Active Users" textFill="#757575" />
                                <Label text="20" textFill="#2D5F4E">
                                    <font>
                                        <Font name="System Bold" size="26.0" />
                                    </font>
                                </Label>
                                <Label text="● Currently active" textFill="#4CAF50" />
                            </children>
                        </VBox>
                        <VBox prefHeight="110.0" style="-fx-background-color: white; -fx-background-radius: 15; -fx-padding: 20; -fx-effect: dropshadow(three-pass-box, rgba(0,0,0,0.05), 10, 0, 0, 5);" HBox.hgrow="ALWAYS">
                            <children>
                                <Label text="Inactive Users" textFill="#757575" />
                                <Label text="4" textFill="#2D5F4E">
                                    <font>
                                        <Font name="System Bold" size="26.0" />
                                    </font>
                                </Label>
                                <Label text="● Disabled accounts" textFill="#FF9800" />
                            </children>
                        </VBox>
                        <VBox prefHeight="110.0" style="-fx-background-color: white; -fx-background-radius: 15; -fx-padding: 20; -fx-effect: dropshadow(three-pass-box, rgba(0,0,0,0.05), 10, 0, 0, 5);" HBox.hgrow="ALWAYS">
                            <children>
                                <Label text="New This Month" textFill="#757575" />
                                <Label text="3" textFill="#2D5F4E">
                                    <font>
                                        <Font name="System Bold" size="26.0" />
                                    </font>
                                </Label>
                                <Label text="● Recently added" textFill="#4CAF50" />
                            </children>
                        </VBox>
                    </children>
                </HBox>

                <VBox spacing="15.0" style="-fx-background-color: white; -fx-background-radius: 20; -fx-padding: 25; -fx-effect: dropshadow(three-pass-box, rgba(0,0,0,0.05), 15, 0, 0, 5);" VBox.vgrow="ALWAYS">
                    <children>
                        <HBox alignment="CENTER_LEFT" spacing="15.0">
                            <children>
                                <TextField prefHeight="38.0" prefWidth="280.0" promptText="Search by ID or Name ..." style="-fx-background-radius: 8;" />
                                <ComboBox prefHeight="38.0" prefWidth="140.0" promptText="All Roles" style="-fx-background-color: white; -fx-border-color: #E0E0E0; -fx-border-radius: 8;" />
                                <ComboBox prefHeight="38.0" prefWidth="140.0" promptText="All Status" style="-fx-background-color: white; -fx-border-color: #E0E0E0; -fx-border-radius: 8;" />
                                <Region HBox.hgrow="ALWAYS" />
                                <Button onAction="#btnAddNewUserOnAction" prefHeight="42.0" prefWidth="168.0" style="-fx-background-color: #2D5F4E; -fx-text-fill: white; -fx-background-radius: 12; -fx-font-weight: bold; -fx-cursor: hand;" text="+ Add New User">
                                    <font>
                                        <Font size="13.0" />
                                    </font>
                                </Button>
                            </children>
                        </HBox>

                        <TableView fx:id="tblUser" prefHeight="420.0" style="-fx-background-radius: 10; -fx-border-radius: 10;" VBox.vgrow="ALWAYS">
                            <columns>
                                <TableColumn fx:id="colId" prefWidth="60.0" text="ID" />
                                <TableColumn fx:id="colFullName" prefWidth="160.0" text="Full Name" />
                                <TableColumn fx:id="colUsername" prefWidth="110.0" text="UserName" />
                                <TableColumn fx:id="colRole" prefWidth="110.0" text="Role" />
                                <TableColumn fx:id="colEmail" prefWidth="200.0" text="Email" />
                                <TableColumn fx:id="colAddress" prefWidth="150.0" text="Address" />
                                <TableColumn fx:id="colStatus" prefWidth="100.0" text="Status" />
                                <TableColumn fx:id="colActions" prefWidth="110.0" text="Actions" />
                            </columns>
                            <columnResizePolicy>
                                <TableView fx:constant="CONSTRAINED_RESIZE_POLICY" />
                            </columnResizePolicy>
                        </TableView>
                    </children>
                </VBox>
            </children>
        </VBox>
    </children>
</AnchorPane>
